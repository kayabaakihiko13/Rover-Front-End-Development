{
  "name": "rover-front-end-development",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:docker": "docker-compose --profile dev up --env-file .env.dev --build",
    "dev:docker:detached": "docker-compose --profile dev up --env-file .env.dev -d",
    "prod:docker": "docker-compose --profile prod up --env-file .env --build",
    "prod:docker:detached": "docker-compose --profile prod up --env-file .env -d",
    "build": "vite build --mode dev",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose up --env-file .env.dev --profile dev --build --force-recreate"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "axios": "^1.13.2",
    "jwt-decode": "^4.0.0",
    "lucide-vue-next": "^0.577.0",
    "sortablejs": "^1.15.6",
    "tailwindcss": "^4.1.17",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "vite": "^7.2.2"
  }
}
